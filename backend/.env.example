# Copy to .env and fill in your own values. Do not commit .env.

MONGO_URI=mongodb+srv://USER:PASSWORD@cluster.example.mongodb.net/task-tracer?retryWrites=true&w=majority

JWT_SECRET=use-a-long-random-string-in-production
JWT_EXPIRE=7d

PORT=5000
NODE_ENV=development

# Optional: for CORS when frontend is on another origin (e.g. production URL)
# CLIENT_URL=https://your-app.onrender.com
